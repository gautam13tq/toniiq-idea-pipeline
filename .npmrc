; Supply-chain hardening — mirrors ~/.npmrc so CI, contractors, agents,
; and fresh clones inherit the same protections as the developer machine.
; Anchored 2026-05-12 after the Mini Shai-Hulud/TanStack npm compromise.
; See /Users/gautam/Supply_Chain_Security_Handoff_2026-05-12_v2.md
;
; Only install versions that have been on the registry for ≥3 days.
; Override per-command with `npm install --min-release-age=0`.
min-release-age=3

; Block preinstall/install/postinstall/prepare scripts. The primary
; npm-supply-chain execution path. Opt in per-command for legit native
; packages (sharp, esbuild, playwright):
;   npm install <pkg> --ignore-scripts=false --foreground-scripts
;   npm rebuild <pkg> --foreground-scripts
ignore-scripts=true

; Pin new direct deps exactly in package.json (lockfile already does this
; for transitives).
save-exact=true

; Audit runs fail on high/critical findings.
audit-level=high
